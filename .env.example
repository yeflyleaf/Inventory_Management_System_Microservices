# ============================================================================
# 进销存管理系统 (微服务版) - 环境变量配置模板
# ============================================================================

# --- 数据库配置 (MySQL) ---
MYSQL_USERNAME=user1
MYSQL_PASSWORD=user1
MYSQL_PORT=3306

# --- Redis 配置 ---
REDIS_PORT=6379

# --- Nacos 配置 ---
NACOS_HOST=nacos

# --- 系统配置 ---
TZ=Asia/Shanghai

# --- JVM 参数 (给微服务使用) ---
JAVA_OPTS=-Xms256m -Xmx512m
