# Using Android gitignore template: https://github.com/github/gitignore/blob/HEAD/Android.gitignore
# 使用 Android gitignore 模板

# Built application files
# 编译生成的应用文件
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
# ART/Dalvik 虚拟机文件
*.dex

# Java class files
# Java 类文件
*.class

# Generated files
# 生成的文件
bin/
gen/
out/
#  Uncomment the following line in case you need and you don't have the release build type files in your app
#  如果您需要且应用中没有 release 构建类型文件，请取消下面行的注释
# release/

# Gradle files
# Gradle 构建文件
.gradle/
build/

# Local configuration file (sdk path, etc)
# 本地配置文件 (SDK 路径等)
local.properties

# Proguard folder generated by Eclipse
# Eclipse 生成的 Proguard 文件夹
proguard/

# Log Files
# 日志文件
*.log

# Android Studio Navigation editor temp files
# Android Studio 导航编辑器临时文件
.navigation/

# Android Studio captures folder
# Android Studio 捕获文件夹
captures/

# IntelliJ
# IntelliJ IDEA 项目文件
*.iml
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
# Android Studio 3 in .gitignore file.
# Android Studio 3 的 .gitignore 文件
.idea/caches
.idea/modules.xml
# Comment next line if keeping position of elements in Navigation Editor is relevant for you
# 如果保留导航编辑器中元素的位置对您很重要，请注释下一行
.idea/navEditor.xml

# Keystore files
# 密钥库文件
# Uncomment the following lines if you do not want to check your keystore files in.
# 如果您不想将密钥库文件提交到版本控制，请取消下面行的注释
#*.jks
#*.keystore

# External native build folder generated in Android Studio 2.2 and later
# Android Studio 2.2 及更高版本生成的外部原生构建文件夹
.externalNativeBuild
.cxx/

# Google Services (e.g. APIs or Firebase)
# Google 服务 (例如 API 或 Firebase)
# google-services.json

# Freeline
# Freeline 构建工具文件
freeline.py
freeline/
freeline_project_description.json

# fastlane
# fastlane 自动化工具文件
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
fastlane/readme.md

# Version control
# 版本控制配置文件
vcs.xml

# lint
# lint 代码检查文件
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/
# lint/reports/

# Android Profiling
# Android 性能分析文件
*.hprof

# Cordova plugins for Capacitor
# Capacitor 的 Cordova 插件
capacitor-cordova-android-plugins

# Copied web assets
# 复制的 Web 资源
app/src/main/assets/public

# Generated Config files
# 生成的配置文件
app/src/main/assets/capacitor.config.json
app/src/main/assets/capacitor.plugins.json
app/src/main/res/xml/config.xml
